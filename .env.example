# Copy to `.env` for local development (never commit `.env`).
# All variables are prefixed with `CC_` (Cricket Companion).

# Environment
CC_ENV=local

# LLM
CC_MODEL=gpt-4o-mini
CC_OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE

# Web
CC_TAVILY_API_KEY=YOUR_TAVILY_KEY_HERE
CC_WEB_CACHE_TTL_DAYS=7

# AWS / S3 (used for web cache + FAISS artifacts in production)
CC_AWS_REGION=us-east-1
CC_S3_BUCKET=YOUR_S3_BUCKET_HERE
CC_S3_PREFIX=cricket-companion

# Standardized local-only folders
CC_DATA_DIR=data
CC_ARTIFACTS_DIR=artifacts
CC_CACHE_DIR=cache
CC_LOGS_DIR=logs

# Default tool timeouts (seconds)
CC_TIMEOUT_STATS_S=10
CC_TIMEOUT_WEB_S=30
CC_TIMEOUT_SIM_S=20
CC_TIMEOUT_FANTASY_S=20

