# Copy to `.env` for local development (never commit `.env`).
# All variables are prefixed with `CC_` (Cricket Companion).

# Environment
CC_ENV=local

# Router mode
# - real: conservative heuristics, falls back to LLM more often
# - easy: permissive heuristics (saves tokens for manual runs)
CC_ROUTER_MODE=real

# LLM
CC_MODEL=gpt-4o-mini
CC_OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE

# Web
CC_TAVILY_API_KEY=YOUR_TAVILY_KEY_HERE
CC_WEB_CACHE_TTL_DAYS=7

# AWS / S3 (used for web cache + FAISS artifacts in production)
CC_AWS_REGION=us-east-1
CC_S3_BUCKET=YOUR_S3_BUCKET_HERE
CC_S3_PREFIX=cricket-companion

# Standardized local-only folders
CC_DATA_DIR=data
CC_ARTIFACTS_DIR=artifacts
CC_CACHE_DIR=cache
CC_LOGS_DIR=logs

# Default tool timeouts (seconds)
CC_TIMEOUT_STATS_S=10
CC_TIMEOUT_WEB_S=30
CC_TIMEOUT_SIM_S=20
CC_TIMEOUT_FANTASY_S=20

# -----------------------------------------------------------------------------
# Memory (2.6.1) — DuckDB-backed short-term session memory + LLM summaries
# -----------------------------------------------------------------------------
# DuckDB file for chat session memory (messages + rolling summary)
CC_MEMORY_DB_PATH=data/duckdb/cricket_companion_memory.duckdb
# Keep the last N messages verbatim; summarize older ones
CC_MEMORY_KEEP_LAST_N=20
# Number of oldest messages summarized per summarization pass
CC_MEMORY_SUMMARIZE_CHUNK_N=10
# Hard cap on stored session summary length (characters)
CC_MEMORY_SUMMARY_MAX_CHARS=2000
# Model used for summary updates (can be same as CC_MODEL or a cheaper one)
CC_SUMMARY_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# LLM Answer Composer (2.7.0) — grounded summarizer over tool outputs
# -----------------------------------------------------------------------------
CC_COMPOSER_MODEL=gpt-4o-mini
CC_COMPOSER_MAX_CHARS=2000
